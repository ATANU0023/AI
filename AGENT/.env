# AgentCraft Environment Configuration

# Provider for the models. Options: gemini, openai, anthropic
AGENT_PROVIDER=gemini

# Model names
META_AGENT_MODEL=gemini-2.5-flash
GENERATED_AGENT_MODEL=gemini-2.5-flash

# API Keys (Fill these in)
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
